direction: right

title: {
  label: "MIDI Looper — hierarchical state machines"
  shape: text
  near: top-center
}

start: {
  label: ""
  shape: circle
  width: 18
  height: 18
  style.fill: "#333333"
  style.stroke: "#333333"
}

master: {
  label: "Master GoF FSM — one global recorder"
  direction: right
  style.fill: "#fafafa"
  style.stroke: "#666666"

  ready: "Ready\nlive routing; zero or more slots may loop"
  ready_selecting_slot: "ReadySelectingLoopSlot\nwaiting for raw slot key"
  ready_selecting_soundfont: "ReadySelectingSoundFont\nwaiting for raw SoundFont key"
  armed: "Armed\none selected recording SlotId"
  armed_selecting_soundfont: "ArmedSelectingSoundFont\npending-slot SoundFont selector"
  recording: "Recording\none pending mutable take"
  stopped: "Stopped\nterminal"

  ready -> ready_selecting_slot: "loopSlotControlPressed()"
  ready_selecting_slot -> ready: "selector canceled or unmapped key consumed"
  ready_selecting_slot -> armed: "raw NoteOn selects Muted slot\n/ clear; snapshot live selection; arm"
  ready_selecting_slot -> ready: "raw NoteOn selects Looping slot\n/ mute only selected slot"

  ready -> ready_selecting_soundfont: "soundFontByNotePressed()"
  ready_selecting_soundfont -> ready: "raw NoteOn or cancel\n/ live selection note consumed"
  ready_selecting_soundfont -> ready_selecting_slot: "loopSlotControlPressed()"

  armed -> recording: "first positive NoteOn\n/ monitor selected slot; record at 0ms"
  armed -> armed_selecting_soundfont: "soundFontByNotePressed()"
  armed_selecting_soundfont -> armed: "raw NoteOn or selector cancel\n/ pending selection note consumed"
  armed -> ready: "loopSlotControlPressed()\n/ cancel and discard pending take"
  armed_selecting_soundfont -> ready: "loopSlotControlPressed()\n/ cancel and discard pending take"

  recording -> recording: "MIDI\n/ monitor selected slot; timestamp notes"
  recording -> ready: "loopSlotControlPressed()\n/ commit snapshot; start selected slot"

  ready -> ready: "ordinary MIDI / monitor live"
  armed -> armed: "ordinary MIDI / monitor selected slot"

  ready -> stopped: "shutdownRequested()"
  ready_selecting_slot -> stopped: "shutdownRequested()"
  ready_selecting_soundfont -> stopped: "shutdownRequested()"
  armed -> stopped: "shutdownRequested()"
  armed_selecting_soundfont -> stopped: "shutdownRequested()"
  recording -> stopped: "shutdownRequested()"
  stopped -> stopped: "any stimulus / no action"
}

slot: {
  label: "Each LoopSlot subordinate playback FSM"
  direction: right
  style.fill: "#f2f8ff"
  style.stroke: "#285f9e"

  muted: "Muted\nnot playing; no resumable take"
  looping: "Looping\ndedicated free-running worker/channel"
  terminated: "Terminated\nworker joined"

  muted -> looping: "startRequested\n/ activatePlayback"
  looping -> muted: "muteRequested\n/ deactivatePlayback; discard take"
  muted -> terminated: "terminationRequested\n/ terminatePlayback"
  looping -> terminated: "terminationRequested\n/ terminatePlayback"
  muted -> muted: "muteRequested / no action"
  looping -> looping: "startRequested / no action"
  terminated -> terminated: "any command / no action"
}

start -> master.ready
master.ready -> slot.muted: {
  label: "Application owns ordered slot catalog\nand raw-key lookup"
  style.stroke-dash: 4
}

legend: {
  label: "Ownership"
  direction: down
  master_data: "Master data: selected recording SlotId + start time"
  application: "Application: pending take + live selector/transposer + slot catalog"
  slot_data: "LoopSlot: id/key/channel + locked SoundFont/octave + immutable take + jthread"
}

slot.looping -> legend: {
  style.opacity: 0
}
